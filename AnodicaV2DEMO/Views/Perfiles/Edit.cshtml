@model AnodicaV2DEMO.ViewModels.PerfilVM

@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-warning text-dark">
        <h3 class="card-title mb-0"><i class="bi bi-pencil-square"></i> Editar Perfil Industrial</h3>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Perfil.PerfilID" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h5 class="text-primary border-bottom pb-2 mb-3">Clasificación</h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Proveedor</label>
                    <select asp-for="ProveedorId" asp-items="@Model.ProveedoresList" class="form-select" id="comboProveedor">
                        <option disabled value="">-- Seleccione un Proveedor --</option>
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.LineaRef" class="form-label fw-bold">Línea</label>
                    <select asp-for="Perfil.LineaRef" asp-items="@Model.LineasList" class="form-select" id="comboLinea">
                        <option disabled value="">-- Seleccione una Línea --</option>
                    </select>
                    <span asp-validation-for="Perfil.LineaRef" class="text-danger"></span>
                </div>
            </div>

            <h5 class="text-primary border-bottom pb-2 mb-3 mt-2">Datos del Perfil</h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PerfilCodigoAlcemar" class="form-label fw-bold">Código</label>
                    <input asp-for="Perfil.PerfilCodigoAlcemar" class="form-control" placeholder="Ej: ALC-1020" />
                    <span asp-validation-for="Perfil.PerfilCodigoAlcemar" class="text-danger"></span>
                </div>
                <div class="col-md-8 mb-3">
                    <label asp-for="Perfil.Descripcion" class="form-label fw-bold">Descripción</label>
                    <input asp-for="Perfil.Descripcion" class="form-control" />
                    <span asp-validation-for="Perfil.Descripcion" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PesoXmetro" class="form-label fw-bold">Peso / Metro (Kg)</label>
                    <input asp-for="Perfil.PesoXmetro" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Perfil.PesoXmetro" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.LongTiraMts" class="form-label fw-bold">Longitud Tira (Mts)</label>
                    <input asp-for="Perfil.LongTiraMts" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Perfil.LongTiraMts" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.CantTirasPaquete" class="form-label fw-bold">Tiras / Paquete</label>
                    <input asp-for="Perfil.CantTirasPaquete" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Perfil.CantTirasPaquete" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Imagen del Perfil</label>

                <input type="file" name="archivos" id="subidaArchivo" class="form-control form-control-sm mb-1" style="max-width: 340px;" accept="image/png, image/jpeg" />
                <small class="text-muted">Dejar en blanco para conservar la imagen actual.</small>
                <div class="mb-2 mt-2" id="contenedorImagen">
                    @if (Model.Perfil.ImagenPerfil != null && Model.Perfil.ImagenPerfil.Length > 0)
                    {
                        var base64 = Convert.ToBase64String(Model.Perfil.ImagenPerfil);
                        var imgSrc = String.Format("data:image/jpeg;base64,{0}", base64);

                        <div class="border border-secondary rounded bg-white d-flex align-items-center justify-content-center overflow-hidden shadow-sm" style="height: 120px; width: 150px;">
                            <img id="previewImagen" src="@imgSrc" style="width: 100%; height: 100%; object-fit: contain;" alt="Imagen actual del perfil" />
                        </div>
                    }
                    else
                    {
                        <div class="border border-secondary rounded bg-dark-subtle d-flex align-items-center justify-content-center overflow-hidden shadow-sm" style="height: 120px; width: 150px;">
                            <img id="previewImagen" src="https://placehold.co/150x120?text=Sin+imagen" style="width: 100%; height: 100%; object-fit: contain;" alt="Nueva imagen" />
                        </div>
                    }
                </div>
            </div>

            <h5 class="text-primary border-bottom pb-2 mb-3 mt-4"><i class="bi bi-palette"></i> Ubicación y Stock Mínimo por Tratamiento</h5>
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%; text-align: center;">Aplica</th>
                            <th style="width: 25%;">Tratamiento</th>
                            <th style="width: 40%;">Ubicación Física</th>
                            <th style="width: 30%;">Stock Mínimo (Tiras)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Tratamientos.Count; i++)
                        {
                            <tr>
                                <td class="text-center">
                                    <div class="form-check d-flex justify-content-center">
                                        <input class="form-check-input" type="checkbox" asp-for="Tratamientos[i].EstaSeleccionado" style="transform: scale(1.3);" />
                                    </div>
                                    <input type="hidden" asp-for="Tratamientos[i].TratamientoRef" />
                                    <input type="hidden" asp-for="Tratamientos[i].TratamientoNombre" />
                                </td>
                                <td class="fw-bold text-secondary">
                                    @Model.Tratamientos[i].TratamientoNombre
                                </td>
                                <td>
                                    <select asp-for="Tratamientos[i].UbicacionRef" asp-items="@Model.UbicacionesList" class="form-select form-select-sm">
                                    </select>
                                </td>
                                <td>
                                    <input asp-for="Tratamientos[i].CantMinimaTirasStock" class="form-control form-control-sm" type="number" min="0" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-4 border-top pt-3 text-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                <button type="submit" class="btn btn-warning px-4">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('#comboProveedor').on('change', function () {
                var proveedorId = $(this).val();
                var comboLinea = $('#comboLinea');
                comboLinea.empty();
                comboLinea.append('<option selected disabled>Cargando líneas...</option>');
                comboLinea.prop('disabled', true);

                if (proveedorId) {
                    $.ajax({
                        url: '/Perfiles/ObtenerLineasPorProveedor',
                        type: 'GET',
                        data: { proveedorId: proveedorId },
                        success: function (data) {
                            comboLinea.empty();
                            comboLinea.append('<option selected disabled value="">-- Seleccione una Línea --</option>');
                            $.each(data, function (index, item) {
                                comboLinea.append($('<option>', {
                                    value: item.value,
                                    text: item.text
                                }));
                            });
                            comboLinea.prop('disabled', false);
                        },
                        error: function () {
                            alert("Error al intentar cargar las líneas. Verifique su conexión.");
                        }
                    });
                }
            });
        });

        document.getElementById("subidaArchivo")?.addEventListener("change", function (e) {
            const file = e.target.files[0];
            const imgPreview = document.getElementById("previewImagen");
            const msgSinImagen = document.getElementById("mensajeSinImagen");

            if (file) {
                if (this.dataset.lastUrl) URL.revokeObjectURL(this.dataset.lastUrl);

                const url = URL.createObjectURL(file);
                imgPreview.src = url;
                imgPreview.classList.remove("d-none");
                if(msgSinImagen) msgSinImagen.classList.add("d-none");

                this.dataset.lastUrl = url;
            }
        });
    </script>
}