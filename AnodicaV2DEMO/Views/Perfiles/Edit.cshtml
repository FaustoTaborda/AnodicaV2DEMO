@model AnodicaV2DEMO.ViewModels.PerfilVM

@{
    ViewData["Title"] = "Editar Perfil";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-warning text-dark">
        <h3 class="card-title mb-0"><i class="bi bi-pencil-square"></i> Editar Perfil: @Model.Perfil.PerfilCodigoAlcemar</h3>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Perfil.PerfilID" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h5 class="text-warning border-bottom border-warning pb-2 mb-3">Clasificación</h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Proveedor</label>
                    <select asp-for="ProveedorId" asp-items="@Model.ProveedoresList" class="form-select" id="comboProveedor">
                        <option disabled value="">-- Seleccione un Proveedor --</option>
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.LineaRef" class="form-label fw-bold">Línea</label>
                    <select asp-for="Perfil.LineaRef" asp-items="@Model.LineasList" class="form-select" id="comboLinea">
                        <option disabled value="">-- Seleccione una Línea --</option>
                    </select>
                    <span asp-validation-for="Perfil.LineaRef" class="text-danger"></span>
                </div>

                <!--<div class="col-md-4 mb-3">
                    <label asp-for="Perfil.UbicacionRef" class="form-label fw-bold">Ubicación</label>
                    <select asp-for="Perfil.UbicacionRef" asp-items="@Model.UbicacionesList" class="form-select">
                        <option value="">-- Sin Ubicación --</option>
                    </select>
                </div>-->
            </div>

            <h5 class="text-warning border-bottom border-warning pb-2 mb-3 mt-2">Datos del Perfil</h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PerfilCodigoAlcemar" class="form-label fw-bold">Código Alcemar</label>
                    <input asp-for="Perfil.PerfilCodigoAlcemar" class="form-control" />
                    <span asp-validation-for="Perfil.PerfilCodigoAlcemar" class="text-danger"></span>
                </div>
                <div class="col-md-8 mb-3">
                    <label asp-for="Perfil.Descripcion" class="form-label fw-bold">Descripción</label>
                    <input asp-for="Perfil.Descripcion" class="form-control" />
                    <span asp-validation-for="Perfil.Descripcion" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PesoXmetro" class="form-label fw-bold">Peso / Metro (Kg)</label>
                    <input asp-for="Perfil.PesoXmetro" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Perfil.PesoXmetro" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.LongTiraMts" class="form-label fw-bold">Longitud Tira (Mts)</label>
                    <input asp-for="Perfil.LongTiraMts" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Perfil.LongTiraMts" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.CantTirasPaquete" class="form-label fw-bold">Tiras / Paquete</label>
                    <input asp-for="Perfil.CantTirasPaquete" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Perfil.CantTirasPaquete" class="text-danger"></span>
                </div>
            </div>

            <div class="row mt-3 p-3 bg-light rounded border align-items-center">
                <div class="col-md-2 text-center">
                    @if (Model.Perfil.ImagenPerfil != null)
                    {
                        var base64 = Convert.ToBase64String(Model.Perfil.ImagenPerfil);
                        var imgsrc = string.Format("data:image/jpeg;base64,{0}", base64);
                        <img src="@imgsrc" alt="Foto Actual" class="img-thumbnail shadow-sm" style="max-height: 80px;" />
                    }
                    else
                    {
                        <div class="p-3 text-muted border rounded border-secondary" style="border-style: dashed !important;">
                            <small>Sin imagen</small>
                        </div>
                    }
                </div>
                <div class="col-md-7">
                    <label class="form-label fw-bold">Reemplazar Imagen</label>
                    <input type="file" name="archivos" id="subidaArchivo" class="form-control" accept="image/png, image/jpeg" />
                    <small class="text-muted">Si no seleccionás nada, se mantendrá la imagen actual.</small>
                </div>
                <div class="col-md-3 text-end pt-3">
                    <div class="form-check form-switch d-inline-block fs-5 text-start">
                        <input class="form-check-input" type="checkbox" asp-for="Perfil.ManejaStockPropio">
                        <label class="form-check-label fs-6 mt-1 ms-2" asp-for="Perfil.ManejaStockPropio">Maneja Stock Propio</label>
                    </div>
                </div>
            </div>

            <div class="mt-4 border-top pt-3 text-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                <button type="submit" class="btn btn-warning fw-bold px-4">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('#comboProveedor').on('change', function () {
                var proveedorId = $(this).val();
                var comboLinea = $('#comboLinea');

                comboLinea.empty();
                comboLinea.append('<option selected disabled>Cargando líneas...</option>');
                comboLinea.prop('disabled', true);

                if (proveedorId) {
                    $.ajax({
                        url: '/Perfiles/ObtenerLineasPorProveedor',
                        type: 'GET',
                        data: { proveedorId: proveedorId },
                        success: function (data) {
                            comboLinea.empty();
                            comboLinea.append('<option selected disabled value="">-- Seleccione una Línea --</option>');

                            $.each(data, function (index, item) {
                                comboLinea.append($('<option>', {
                                    value: item.value,
                                    text: item.text
                                }));
                            });

                            comboLinea.prop('disabled', false);
                        },
                        error: function () {
                            alert("Error al cargar las líneas.");
                        }
                    });
                }
            });
        });
    </script>
}