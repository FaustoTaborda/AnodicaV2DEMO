@model AnodicaV2DEMO.ViewModels.PerfilVM

@{
    ViewData["Title"] = "Crear Perfil";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-primary text-white">
        <h3 class="card-title mb-0"><i class="bi bi-box-seam"></i> Nuevo Perfil Industrial</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h5 class="text-primary border-bottom pb-2 mb-3">Clasificación</h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Proveedor</label>
                    <select asp-for="ProveedorId" asp-items="@Model.ProveedoresList" class="form-select" id="comboProveedor">
                        <option disabled selected value="">-- Seleccione un Proveedor --</option>
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.LineaRef" class="form-label fw-bold">Línea</label>
                    <select asp-for="Perfil.LineaRef" class="form-select" id="comboLinea" disabled>
                        <option disabled selected value="">-- Primero elija un Proveedor --</option>
                    </select>
                    <span asp-validation-for="Perfil.LineaRef" class="text-danger"></span>
                </div>
            </div>

            <h5 class="text-primary border-bottom pb-2 mb-3 mt-2">Datos del Perfil</h5>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PerfilCodigoAlcemar" class="form-label fw-bold">Código</label>
                    <input asp-for="Perfil.PerfilCodigoAlcemar" class="form-control" placeholder="Ej: ALC-1020" />
                    <span asp-validation-for="Perfil.PerfilCodigoAlcemar" class="text-danger"></span>
                </div>
                <div class="col-md-8 mb-3">
                    <label asp-for="Perfil.Descripcion" class="form-label fw-bold">Descripción</label>
                    <input asp-for="Perfil.Descripcion" class="form-control" />
                    <span asp-validation-for="Perfil.Descripcion" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.PesoXmetro" class="form-label fw-bold">Peso / Metro (Kg)</label>
                    <input asp-for="Perfil.PesoXmetro" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Perfil.PesoXmetro" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.LongTiraMts" class="form-label fw-bold">Longitud Tira (Mts)</label>
                    <input asp-for="Perfil.LongTiraMts" class="form-control" type="number" step="0.01" min="0" />
                    <span asp-validation-for="Perfil.LongTiraMts" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Perfil.CantTirasPaquete" class="form-label fw-bold">Tiras / Paquete</label>
                    <input asp-for="Perfil.CantTirasPaquete" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Perfil.CantTirasPaquete" class="text-danger"></span>
                </div>
            </div>

            <div class="row align-items-center mt-2">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Imagen del Perfil</label>
                    <input type="file" name="archivos" id="subidaArchivo" class="form-control" accept="image/png, image/jpeg" />
                </div>
                <div class="col-md-6 mb-3 text-end pt-4">
                    <div class="form-check form-switch d-inline-block fs-5 text-start">
                        <input class="form-check-input" type="checkbox" asp-for="Perfil.ManejaStockPropio" checked>
                        <label class="form-check-label fs-6 mt-1 ms-2" asp-for="Perfil.ManejaStockPropio">Maneja Stock Propio</label>
                    </div>
                </div>
            </div>

            <div class="mt-4 border-top pt-3 text-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                <button type="submit" class="btn btn-primary px-4">Guardar Perfil</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('#comboProveedor').on('change', function () {
                var proveedorId = $(this).val();
                var comboLinea = $('#comboLinea');
                comboLinea.empty();
                comboLinea.append('<option selected disabled>Cargando líneas...</option>');
                comboLinea.prop('disabled', true); 
     
                if (proveedorId) {
                    $.ajax({
                        url: '/Perfiles/ObtenerLineasPorProveedor',
                        type: 'GET',
                        data: { proveedorId: proveedorId },
                        success: function (data) {
                            comboLinea.empty(); 
                            comboLinea.append('<option selected disabled value="">-- Seleccione una Línea --</option>');
                            $.each(data, function (index, item) {
                                comboLinea.append($('<option>', {
                                    value: item.value,
                                    text: item.text
                                }));
                            });
                            comboLinea.prop('disabled', false);
                        },
                        error: function () {
                            alert("Error al intentar cargar las líneas. Verifique su conexión.");
                        }
                    });
                }
            });
        });
    </script>
}