@model IEnumerable<Anodica.Modelos.InsumoMovimiento>

@{
    ViewData["Title"] = "Historial de Movimientos";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-6">
            <h2 class="text-primary fw-bold">Historial de Movimientos</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                + Registrar Movimiento
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Fecha</th>
                        <th>Insumo</th>
                        <th class="text-center">Tipo</th>
                        <th class="text-end">Cantidad</th>
                        <th class="text-center">Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@item.FechaMovimiento.ToString("dd/MM/yyyy")</td>

                            <td>@item.Insumo.InsumoNombre</td>

                            <td class="text-center">
                                @if (item.EsIngreso)
                                {
                                    <span class="badge bg-success px-3 py-2">Ingreso</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 py-2">Egreso</span>
                                }
                            </td>

                            <td class="text-end fw-bold">
                                @item.Cantidad
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center">
                                    <button class="btn btn-secondary btn-sm" disabled title="Por reglas de auditoría, los movimientos no se pueden editar ni eliminar.">
                                        Bloqueado
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_Notificaciones" />
}