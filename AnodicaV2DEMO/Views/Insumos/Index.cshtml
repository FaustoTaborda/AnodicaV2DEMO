@model IEnumerable<Anodica.Modelos.Insumo>

@{
    ViewData["Title"] = "Listado de Insumos";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-6">
            <h2 class="text-primary fw-bold">Listado de Insumos</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary shadow-sm ">
                + Crear Nuevo Insumo
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0"> 
        <div class="card-body table-responsive-lg">
            <table class="table table-hover align-middle mb-0 tabla-anodica">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Código</th>
                        <th>Nombre</th>
                        <th>Unidad</th>
                        <th>Stock Actual</th>
                        <th>Stock Mínimo</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@item.CodigoInsumo</td>
                            <td>@item.InsumoNombre</td>
                            <td>@item.UnidadMedida</td>
                            <td>@item.CantidadStock</td>
                            <td>@item.CantMinimaStock</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.InsumoID" class="btn btn-warning btn-sm">Editar</a>

                                    <form asp-action="Delete" asp-route-id="@item.InsumoID" method="post" id="form-eliminar-@item.InsumoID">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-danger btn-sm" onclick="ConfirmarEliminacion('@item.InsumoID', '@item.InsumoNombre')">
                                            Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {

}