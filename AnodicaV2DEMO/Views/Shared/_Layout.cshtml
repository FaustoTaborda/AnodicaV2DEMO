<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Anodica</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/AnodicaV2DEMO.styles.css" asp-append-version="true" />
    <script>
        const temaGuardado = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', temaGuardado);
    </script>
</head>

<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom border-bottom box-shadow">
            <div class="container-fluid">

                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-controller="Home"
                   asp-action="Index">
                    <img src="~/images/logo-river.svg" alt="Anódica Logo" style="width:40px;" />
                    Anódica
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                Gestión de Stock
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Insumos" asp-action="Index">Lista de Insumos</a></li>
                                <li><a class="dropdown-item" asp-controller="Insumos" asp-action="Create">Nuevo Insumo</a></li>
                                <li><a class="dropdown-item" asp-controller="Lineas" asp-action="Index">Lineas</a></li>
                                <li><a class="dropdown-item" asp-controller="Perfiles" asp-action="Index">Perfiles</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="InsumoMovimientos" asp-action="Index">Movimientos</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                Stock
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Insumos" asp-action="Index">Insumos</a></li>
                                <li><a class="dropdown-item" asp-controller="Perfiles" asp-action="Index">Perfiles</a></li>
                                <li><a class="dropdown-item" asp-controller="Accesorios" asp-action="Index">Accesorios</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="InsumoMovimientos" asp-action="Index">Movimientos</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                Producción
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#">Órdenes de Trabajo</a></li>
                                <li><a class="dropdown-item" href="#">Planificación</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
                <button id="btnCambiarTema" class="btn btn-outline-light rounded-circle ms-auto me-4 border-opacity-50" title="Cambiar Tema" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i id="iconoTema" class="bi bi-moon-fill text-white fs-5"></i>
                </button>
            </div>
        </nav>
    </header>

    <main class="main-wrapper flex-grow-1">
        <div class="glass-panel d-flex flex-column">

            <div class="container-glass flex-grow-1">
                @RenderBody()
            </div>

            <footer class="footer-glass mt-auto">
                <div class="text-center text-white">
                    &copy; 2026 - Sistema Anódica -
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>

        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
  
    <partial name="_Notificaciones" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>